{
    "manifest_version": 3,
    "name": "NoRagrets",
    "version": "1.0.0"  ,
    "description": "Prevent people from having regrets of not trying their best",
    "permissions": [
        "storage",
        "tabs"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "NoRagrets",
        "default_popup": "index.html"
    },
    
    "options_page": "index.html"
}